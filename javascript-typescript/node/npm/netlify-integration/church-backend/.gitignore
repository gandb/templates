# Node.js + TypeScript

# Local Netlify folder
.netlify/

# Dependencies
node_modules/

# Build outputs
dist/
build/
out/
lib/

#JS files
*.js
*.cjs
*.mjs

# Source maps
*.js.map
*.cjs.map
*.mjs.map

# TypeScript build info
*.tsbuildinfo

# Optional npm cache
.npm/
.pnpm-store/

# Local env files
*.env
*.env.*

# Logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
yarn-error.log*

# Coverage and test output
coverage/
.nyc_output/

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Caches
.cache/
.eslintcache
.rpt2_cache/
.parcel-cache/

# Misc
*.local
*.swp

# Netlify local build artifacts (if any)
.netlify/

# Framework-specific caches (optional)
.vite/
.next/
.nuxt/

# Ignore TypeScript generated declaration files in build folders (if emitted)
# (Keep if you actually want to commit *.d.ts files)
# **/dist/**/*.d.ts

# Keep lockfiles (recommended to commit). Remove the next lines if you don't want them ignored.
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
