{
    "name": "Open Node Com Typescript",
    "image": "node:22-slim", 

    // workspaceFolder é o diretório que vai ficar o fonte  
    "workspaceFolder": "/buildspace",
    // workspaceMount do jeito que está faz um bind com a pasta local, o que ocorre em um lugar se repete no outro
    "workspaceMount": "source=${localWorkspaceFolder},target=/buildspace,type=bind",

    // Configura variaveis que estarão disponíveis no container, estas variaveis nao ficam disponíveis no host
    "containerEnv": {
        //"DATABASE_HOST": "${env:DATABASE_HOST}",
        "VARIAVEL_EXEMPLO_01": "Teste1",
        "VARIAVEL_EXEMPLO_02": "Teste2"

    },

    /* Add extra hosts -estudar pra que serve
