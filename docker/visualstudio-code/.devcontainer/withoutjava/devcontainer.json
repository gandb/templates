        "-v/var/run/docker.sock:/var/run/docker.sock",
        "-v${localWorkspaceFolder}/tmp/vscode-server-nojava:/home/scatex/.vscode-server"
    ],
    "remoteUser": "gandb", 
    */
    
    // Extensions to install inside the container
    "customizations": {
        "vscode": {
            "extensions": [ 
               /* "ms-vscode.cpptools",
